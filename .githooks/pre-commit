#!/bin/sh
# Keeps the anchor-render cache-buster (?v=...) in the app HTML in sync with
# the actual render files, so replaced renders can never be masked by stale
# browser caches. See .githooks/sync_render_version.py for the full story.
#
# One-time setup per clone:  git config core.hooksPath .githooks
python .githooks/sync_render_version.py || exit 1
